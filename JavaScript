// Lista de convidados
const convidados = ["Ana", "Bruno", "Amanda", "Carlos", "Beatriz", "Alberto", "Daniela"];

// Função principal que organiza as listas
function processarListas() {
    let nomesMaiusculos = [];
    let nomesComA = [];
    let nomesLongos = [];
    let contadorA = 0;

    // Iterando sobre os nomes com range()
    for (let i = 0; i < convidados.length; i++) {
        let nome = convidados[i];

        // Adicionando os nomes em maiúsculas
        nomesMaiusculos.push(nome.toUpperCase());

        // Contando e adicionando nomes que começam com 'A'
        if (nome[0].toUpperCase() === 'A') {
            nomesComA.push(nome);
            contadorA++;
        }

        // Adicionando nomes com mais de 5 letras
        if (nome.length > 5) {
            nomesLongos.push(nome);
        }
    }

    // Exibindo as listas de convidados na página
    exibirLista('maiusculas', nomesMaiusculos);
    exibirLista('com-a', nomesComA);
    exibirLista('longos', nomesLongos);
    
    // Exibindo o número de nomes que começam com a letra 'A'
    document.getElementById('total-a').textContent = `Total de nomes que começam com 'A': ${contadorA}`;
}

// Função para exibir a lista na página
function exibirLista(id, lista) {
    const ul = document.getElementById(id);
    ul.innerHTML = ''; // Limpa a lista antes de adicionar novos itens
    lista.forEach(nome => {
        const li = document.createElement('li');
        li.textContent = nome;
        ul.appendChild(li);
    });
}

// Chama a função para processar e exibir as listas assim que a página for carregada
document.addEventListener('DOMContentLoaded', processarListas);
