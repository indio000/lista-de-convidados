// Lista de convidados
const convidados = ["Ana", "Bruno", "Amanda", "Carlos", "Beatriz", "Alberto", "Daniela"];

// Função para processar os dados e exibir as listas
function processarListas() {
    let nomesMaiusculos = [];
    let nomesComA = [];
    let nomesLongos = [];
    let contadorA = 0;

    // Loop para iterar sobre os convidados
    for (let i = 0; i < convidados.length; i++) {
        let nome = convidados[i];

        // Nomes em maiúsculas
        nomesMaiusculos.push(nome.toUpperCase());

        // Nomes que começam com 'A'
        if (nome[0].toUpperCase() === 'A') {
            nomesComA.push(nome);
            contadorA++;
        }

        // Nomes com mais de 5 letras
        if (nome.length > 5) {
            nomesLongos.push(nome);
        }
    }

    // Exibir listas no HTML
    exibirLista('maiusculas', nomesMaiusculos);
    exibirLista('com-a', nomesComA);
    exibirLista('longos', nomesLongos);
    
    // Exibir quantidade de nomes que começam com 'A'
    document.getElementById('total-a').innerText = `Total de nomes que começam com 'A': ${contadorA}`;
}

// Função para exibir uma lista no HTML
function exibirLista(id, lista) {
    const ul = document.getElementById(id);
    ul.innerHTML = '';
    lista.forEach(nome => {
        const li = document.createElement('li');
        li.textContent = nome;
        ul.appendChild(li);
    });
}

// Chama a função para processar e exibir as listas
processarListas();
