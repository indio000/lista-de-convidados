// Lista Original de Convidados
const convidados = ["Alice", "Bruno", "Amanda", "Carlos", "Beatriz", "Augusto", "Ricardo", "Ana"];

// 1. Criando uma função que simula o range() para iterar
const range = (start, end) => Array.from({ length: end - start }, (v, k) => k + start);

// Selecionando elementos do DOM
const ulMaiuscula = document.getElementById('lista-maiuscula');
const ulLongos = document.getElementById('lista-longos');
const pContagemA = document.getElementById('contagem-a');

// Variáveis de controle
let nomesLongos = [];
let contadorA = 0;

// Usando o range para o loop (do índice 0 até o tamanho da lista)
const indices = range(0, convidados.length);

indices.forEach(i => {
    const nome = convidados[i];

    // Lógica 1: Transformar em Maiúsculo e imprimir na tela
    let li = document.createElement('li');
    li.textContent = nome.toUpperCase();
    ulMaiuscula.appendChild(li);

    // Lógica 2: Contar nomes que começam com "A"
    if (nome.toUpperCase().startsWith('A')) {
        contadorA++;
    }

    // Lógica 3: Lista com nomes com mais de 5 letras
    if (nome.length > 5) {
        nomesLongos.push(nome);
    }
});

// Renderizando a lista de nomes longos
nomesLongos.forEach(nome => {
    let li = document.createElement('li');
    li.textContent = nome;
    ulLongos.appendChild(li);
});

// Exibindo a contagem final
pContagemA.textContent = `Total de convidados que começam com "A": ${contadorA}`;
